{
  "name": "nenxo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:backend": "cd backend && npx tsx watch src/server.ts",
    "dev:frontend": "cd frontend && npx vite --host",
    "build:backend": "cd backend && npx tsc",
    "build:frontend": "cd frontend && npx tsc && npx vite build",
    "build": "npm run build:backend && npm run build:frontend",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.4",
    "typescript": "^5.8.3"
  }
}
